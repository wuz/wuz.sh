{
	"name": "wuz-monorepo",
	"version": "0.0.0",
	"private": true,
	"packageManager": "bun@1.3.13",
	"workspaces": [
		"sites/*",
		"packages/*"
	],
	"scripts": {
		"build:wuz-sh": "turbo run build --filter=@wuz/wuz-sh",
		"build:wuz-quest": "turbo run build --filter=@wuz/wuz-quest",
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"deploy:wuz-sh": "turbo run deploy --filter=@wuz/wuz-sh",
		"deploy:wuz-quest": "turbo run deploy --filter=@wuz/wuz-quest",
		"deploy:all": "turbo run deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"turbo": "^2.5.4"
	}
}
